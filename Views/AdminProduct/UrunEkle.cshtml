@model TedarikciPanel.Models.Product
@{
    ViewData["Title"] = "Ürün Ekle";
}
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<h2>Yeni Ürün Ekle</h2>

@if (ViewBag.Mesaj != null)
{
    <div class="alert alert-success">@ViewBag.Mesaj</div>
}

<form asp-action="UrunEkle" enctype="multipart/form-data" method="post">

    <div class="form-group">
        <label>Ad</label>
        <input asp-for="Ad" class="form-control" />
        <span asp-validation-for="Ad" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Açıklama</label>
        <textarea asp-for="Aciklama" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Fiyat</label>
        <input asp-for="Fiyat" class="form-control" />
        <span asp-validation-for="Fiyat" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Stok</label>
        <input asp-for="Stok" class="form-control" />
    </div>

    <div class="form-group">
        <label>Ürün Resmi</label>
        <input type="file" name="Resim" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Kaydet</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
