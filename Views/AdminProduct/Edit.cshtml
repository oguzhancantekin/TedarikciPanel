@model Product
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}



<h2>Ürünü Düzenle</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Ad</label>
        <input asp-for="Ad" class="form-control" />
    </div>

    <div class="form-group">
        <label>Açıklama</label>
        <textarea asp-for="Aciklama" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Fiyat</label>
        <input asp-for="Fiyat" class="form-control" />
    </div>

    <div class="form-group">
        <label>Stok</label>
        <input asp-for="Stok" class="form-control" />
    </div>

    <div class="form-group">
        <label>Yeni Resim Yükle</label>
        <input type="file" name="Resim" class="form-control" />
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a href="/AdminProduct/Index" class="btn btn-secondary">İptal</a>
    </div>
</form>
