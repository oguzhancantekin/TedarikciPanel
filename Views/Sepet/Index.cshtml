@model List<TedarikciPanel.Models.SepetItem>

@{
    Layout = "~/Views/Shared/_MusteriLayout.cshtml";
    ViewData["Title"] = "Sepetim";
}

<h2>Sepetim</h2>
<p>Sepetinizdeki ürünler aşağıda listelenmiştir.</p>

@if (Model != null && Model.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Ürün</th>
                <th>Adet</th>
                <th>Fiyat</th>
                <th>Ara Toplam</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr>
                    <td>@Model[i].UrunAd</td>
                    <td>@Model[i].Adet</td>
                    <td>@Model[i].Fiyat.ToString("N2") ₺</td>
                    <td>@((Model[i].Fiyat * Model[i].Adet).ToString("N2")) ₺</td>
                    <td>
                        <form asp-action="Sil" asp-controller="Sepet" method="post">
                            <input type="hidden" name="index" value="@i" />
                            <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="3" class="text-end">Toplam:</th>
                <th>@(Model.Sum(x => x.Adet * x.Fiyat).ToString("N2")) ₺</th>
                <th></th>
            </tr>
        </tfoot>
    </table>

    <form asp-action="Onayla" method="post">
        <button type="submit" class="btn btn-success">Siparişi Onayla</button>
    </form>
}
else
{
    <div class="alert alert-info">
        Sepetiniz şu anda boş.
    </div>
}
